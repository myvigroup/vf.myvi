# Supabase (Auth + User-Verwaltung)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=https://vf.myvi.de

# Azure AD (App-Only Zugriff auf SharePoint)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# SharePoint
SHAREPOINT_SITE_ID=
SHAREPOINT_LIST_ID=

# E-Mail (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=MYVI Dialog <noreply@vf.myvi.de>

# Webhook-Secret für Power Automate API-Aufrufe
WEBHOOK_SECRET=your-webhook-secret
