# Power Automate Flow URLs (Outbound: Dashboard → SharePoint)
POWER_AUTOMATE_NEW_DEAL_URL=https://prod-xx.westeurope.logic.azure.com/workflows/...
POWER_AUTOMATE_COMMENT_URL=https://prod-xx.westeurope.logic.azure.com/workflows/...
